#!/usr/bin/env bash
# Pre-commit hook: run parity tests when game engine or simulation files change.
#
# Monitored paths (relative to repo root):
#   - UnityRTS/AgentSDK/           (shared interface layer)
#   - UnityRTS/AgentTestHarness/   (simulation engine)
#   - UnityRTS/RTS/Assets/Scripts/GameManager/  (Unity game engine)
#
# Skip with: git commit --no-verify

set -euo pipefail

# Check if any staged files match the monitored paths
ENGINE_PATHS="UnityRTS/AgentSDK/ UnityRTS/AgentTestHarness/ UnityRTS/RTS/Assets/Scripts/GameManager/"

changed=false
for path in $ENGINE_PATHS; do
    if git diff --cached --name-only | grep -q "^$path"; then
        changed=true
        break
    fi
done

if [ "$changed" = false ]; then
    exit 0
fi

echo "Engine/sim files changed — running parity tests..."

cd "$(git rev-parse --show-toplevel)/UnityRTS"
dotnet.exe test Parity.Tests/Parity.Tests.csproj \
    --nologo \
    --filter "FullyQualifiedName~Parity" \
    -v q

echo "Parity tests passed."
